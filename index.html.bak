  {game:'Whiteout Survival',dc:'https://gall.dcinside.com/mgallery/board/lists/?id=whiteoutsv',pos:28,neg:32,neu:40,desc:'화이트아웃서바이벌 마이너 갤러리 (활성화, 97K+ 게시글)'},
  {game:'리니지M',dc:null,pos:25,neg:38,neu:37},
